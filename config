my_license=LGPLv3

usage() {
	prog=$1
	cat << _EOF
${prog} [<options>]

<options> can be one of the following:

--prefix=<val>		The installation prefix (default: /usr).
--enable-debug		Enable debug mode compilation (default: disabled).
--disable-allocator	Disable use of internal memory allocator mechanism (default: enabled).
--enable-debug-stats	Enable printing of some verbose debug info (default: disabled).
--with-openssl=<path to OpenSSL installation tree> (Default: System)
			This defaults to the system's OpenSSL library. You can use this option
			if you want to use an alternate OpenSSL installation.
--with-zlib=<path to zlib installation tree> (Default: System)
			Enable building against an alternate Zlib installation.
--with-bzlib=<path to Bzip2 library installation tree> (Default: System)
			Enable building against an alternate Bzip2 and library installation.
--with-external-libbsc=<path to libbsc source tree>
			Enable building with exernal libbsc sources. Can be used to link with
			ASLv2 libbsc when using MPLv2 licensed sources.
--wavpack-dir=<path to WavPack source tree>
			Points to the directory containing the WavPack sources. This option
			must be specified if --disable-wavpack is not provided.
--disable-wavpack	Disables the WavPack filter.
--disable-zstd		Disable Zstandard compression support (default: enabled).
--no-sse-detect		Do NOT attempt to probe the system's SSE capability for build flags.
			Implies '--no-avx-detect' below.
--no-avx-detect		Do NOT attempt to probe the system's AVX capability for build flags.
--no-1.3-archive-compat Disable compatibility with compressed archives created with Pcompress
			version 1.3 (default: retain compatibility). Hash formats changed from
			version 1.3 to 1.4 so this option is required if files created using
			1.3 need to be decompressed by version 1.4 onwards.
--limit-key128		Limit key length to 128-bit encryption keys. Otherwise the default is to
			use 256-bit keys changeable at runtime via the '-k <keylen>' option.
--help			Display this help message.

_EOF
exit 0
}

# ----------------------------------------------------------------
# Helper: try pkg-config for a library, echoing libdir if found.
# Usage: try_pkgconfig <pkg-name>
# Returns 0 and prints the libdir on success, 1 on failure.
# ----------------------------------------------------------------
try_pkgconfig() {
	_pkg="$1"
	if command -v pkg-config >/dev/null 2>&1; then
		_dir=$(pkg-config --variable=libdir "$_pkg" 2>/dev/null)
		if [ -n "$_dir" ]; then
			echo "$_dir"
			return 0
		fi
	fi
	return 1
}

# Helper: try pkg-config for include dir
try_pkgconfig_inc() {
	_pkg="$1"
	if command -v pkg-config >/dev/null 2>&1; then
		_dir=$(pkg-config --variable=includedir "$_pkg" 2>/dev/null)
		if [ -n "$_dir" ]; then
			echo "$_dir"
			return 0
		fi
	fi
	return 1
}

# ----------------------------------------------------------------
# Build the list of library search paths for the current platform.
# Accounts for Linux multiarch, Homebrew, MacPorts, FreeBSD, etc.
# Usage: lib_search_paths <prefix>
# ----------------------------------------------------------------
lib_search_paths() {
	_pref="$1"

	# Standard paths
	echo "${_pref}/lib64"
	echo "${_pref}/usr/lib64"
	echo "${_pref}/lib"
	echo "${_pref}/usr/lib"
	echo "${_pref}/local/lib64"
	echo "${_pref}/usr/local/lib64"
	echo "${_pref}/local/lib"
	echo "${_pref}/usr/local/lib"

	# Linux multiarch (Debian/Ubuntu)
	if [ -n "$gnu_arch" ]; then
		echo "${_pref}/lib/${gnu_arch}"
		echo "${_pref}/usr/lib/${gnu_arch}"
		echo "${_pref}/local/lib/${gnu_arch}"
		echo "${_pref}/usr/local/lib/${gnu_arch}"
	fi

	# macOS Homebrew (Intel + Apple Silicon)
	if [ "$OS" = "Darwin" ]; then
		echo "/usr/local/opt/openssl/lib"
		echo "/opt/homebrew/opt/openssl/lib"
		echo "/usr/local/lib"
		echo "/opt/homebrew/lib"
		echo "/opt/local/lib"
	fi

	# FreeBSD
	if [ "$OS" = "FreeBSD" ]; then
		echo "/usr/local/lib"
	fi

	echo "${_pref}/.libs"
	echo "${_pref}"
}

# Similar for include search paths
inc_search_paths() {
	_pref="$1"

	echo "${_pref}/include"
	echo "${_pref}/usr/include"
	echo "${_pref}/local/include"
	echo "${_pref}/usr/local/include"

	if [ "$OS" = "Darwin" ]; then
		echo "/usr/local/opt/openssl/include"
		echo "/opt/homebrew/opt/openssl/include"
		echo "/usr/local/include"
		echo "/opt/homebrew/include"
		echo "/opt/local/include"
	fi

	if [ "$OS" = "FreeBSD" ]; then
		echo "/usr/local/include"
	fi

	echo "${_pref}"
}

arg1=$1
debug=0
allocator=1
debug_stats=0
prefix=/usr

if [ "$my_license" = "LGPLv3" ]
then
	libbsc_dir=./bsc
	libbsc_lib=${libbsc_dir}/libbsc.a
	libbsclflags='\$\(LIBBSCLFLAGS\)'
	libbscwrapobj='\$\(LIBBSCWRAPOBJ\)'
	libbscgenopt='\$\(LIBBSCGEN_OPT\)'
	libbsccppflags='\$\(LIBBSCCPPFLAGS\)'
fi
openssl_prefix=
openssl_libdir=
openssl_incdir=
libbz2_libdir=
libz_libdir=
sha256asmobjs=
sha256objs=
keylen=
yasm=yasm
yasm_params_linux="-f x64 -f elf64 -X gnu -g dwarf2 -D LINUX"
yasm_params_osx="-f macho64 --prefix=_"
yasm_params_gas_osx="-f macho64 -X gnu -p gas --prefix=_"
yasm_params_gas=
keccak_srcs=
keccak_hdrs=
keccak_srcs_asm=
extra_opt_flags=
zlib_prefix=
bzlib_prefix=
sse_detect=1
avx_detect=1
sse_opt_flags="-msse2"
avx_opt_flag="-mavx"
sse4_opt_flag="-msse4.2"
sse3_opt_flag="-mssse3"
sse2_opt_flag="-msse2"
avx512_opt_flag="-mavx512f -mavx512vl"
neon_opt_flag=""
crypto_compat_objs='\$\(CRYPTO_COMPAT_OBJS\)'
crypto_compat_flags="-D__HASH_COMPATIBILITY_"
salsa20_stream_c=
salsa20_stream_asm='\$\(XSALSA20_STREAM_ASM\)'
salsa20_debug=
so_suffix=so
crypto_asm_compile='\$\(CRYPTO_ASM_COMPILE1\)'
use_clang_as=
soname_opt="soname,"
rpath="-R"
dtag_val=',--enable-new-dtags'
lrt="-lrt"
ldl="-ldl"
default_opt="O3"
max_opt="O3"
libarchive_dir="archive/libarchive"
enable_wavpack="-D_ENABLE_WAVPACK_"
wavpack_libspec=""
enable_zstd=1
zstd_objs='\$\(ZSTDOBJS\)'
zstd_wrapobj='\$\(ZSTDWRAPOBJ\)'
zstd_cppflags="-DENABLE_PC_ZSTD"
zstd_incflags="-I./zstd/lib"

# ----------------------------------------------------------------
# Initialize git submodules if present and not yet initialized
# ----------------------------------------------------------------
if [ -f .gitmodules ] && command -v git >/dev/null 2>&1; then
	if git rev-parse --git-dir >/dev/null 2>&1; then
		# Check if any submodule is uninitialized
		uninit=$(git submodule status 2>/dev/null | grep '^-' | head -1)
		if [ -n "$uninit" ]; then
			echo "Initializing git submodules ..."
			git submodule update --init --recursive
			if [ $? -ne 0 ]; then
				echo "WARNING: Failed to initialize git submodules."
				echo "         You may need to run: git submodule update --init --recursive"
			fi
		fi
	fi
fi

# ----------------------------------------------------------------
# Detect compiler
# ----------------------------------------------------------------
if [ "x$GCC" = "x" ]
then
	GCC=gcc
fi

if [ "x$GPP" = "x" ]
then
	GPP=g++
fi

if [ "x$GXX" != "x" ]
then
	GPP="${GXX}"
fi

# Allow CC/CXX environment overrides (common convention)
if [ "x$CC" != "x" ]; then
	GCC="$CC"
fi
if [ "x$CXX" != "x" ]; then
	GPP="$CXX"
fi

rm -rf ./buildtmp
mkdir ./buildtmp

echo "Checking for C compiler (${GCC}) ..."
# Try a simple compilation
cat << _EOF > tst.c
#include <stdio.h>

int
main(void)
{
	long l;
	printf("%lu\n", sizeof (l));
	return (0);
}
_EOF

${GCC} tst.c -o tst
if [ $? -ne 0 ]
then
	echo "ERROR:"
	echo "Cannot compile a simple program. GCC 4.4+ or a compatible C compiler is required"
	echo "to build this program. Please include the compiler's bin directory in the PATH,"
	echo "or set the CC environment variable."
	echo ""
	echo "  Example: CC=gcc-12 ./config"
	echo ""
	rm -f tst.c
	exit 1
fi

# Check bitness of system/toolchain
echo "Checking for 32-bit/64-bit platform ..."
bitness=$(./tst)
if [ "$bitness" -lt 8 ]
then
	# Hmmm maybe default compilation is 32-bit. Re-try with m64 flag.
	${GCC} -m64 tst.c -o tst
	if [ $? -ne 0 ]
	then
		rm -f tst tst.c
		echo "ERROR:"
		echo "Only 64-bit platforms are supported."
		echo ""
		exit 1
	fi

	# If m64 compilation succeeds we assume platform to be 64-bit capable but
	# explicit flag is reqd.
	extra_opt_flags="-m64"
fi
rm -f tst tst.c

while [ "${arg1}" != "" ]
do
	case "$arg1" in
	--enable-debug) debug=1;;
	--disable-allocator) allocator=0;;
	--enable-debug-stats) debug_stats=1;;
	--prefix=*)
		pval=$(echo "${arg1}" | cut -f2 -d"=")
		prefix=$pval
	;;
	--with-openssl=*)
		openssl_prefix=$(echo "${arg1}" | cut -f2 -d"=")
	;;
	--with-zlib=*)
		zlib_prefix=$(echo "${arg1}" | cut -f2 -d"=")
	;;
	--with-bzlib=*)
		bzlib_prefix=$(echo "${arg1}" | cut -f2 -d"=")
	;;
	--with-external-libbsc=*)
		libbsc_dir=$(echo "${arg1}" | cut -f2 -d"=")
		libbsc_lib=${libbsc_dir}/libbsc.a
		libbsclflags='\$\(LIBBSCLFLAGS\)'
		libbscwrapobj='\$\(LIBBSCWRAPOBJ\)'
		libbscgenopt='\$\(LIBBSCGEN_OPT\)'
		libbsccppflags='\$\(LIBBSCCPPFLAGS\)'
	;;
	--wavpack-dir=*)
		wavpack_dir=$(echo "${arg1}" | cut -f2 -d"=")
		wavpack_libspec="-L${wavpack_dir}/src/.libs -lwavpack"
	;;
	--disable-wavpack)
		enable_wavpack=""
		wavpack_libspec=""
	;;
	--disable-zstd)
		enable_zstd=0
		zstd_objs=""
		zstd_wrapobj=""
		zstd_cppflags=""
		zstd_incflags=""
	;;
	--use-key256)
		keylen='-DDEFAULT_KEYLEN=16'
	;;
	--no-sse-detect)
		sse_detect=0
		avx_detect=0
	;;
	--no-avx-detect)
		avx_detect=0
	;;
	--no-1.3-archive-compat)
		crypto_compat_objs=""
		crypto_compat_flags=""
	;;
	--help) usage $0;;
	*)
		echo "Unrecognized option: ${arg1}"
		exit 1
	;;
	esac
	shift
	arg1=$1
done

# Auto-detect WavPack submodule if not explicitly specified
if [ "x${enable_wavpack}" != "x" ] && [ "x${wavpack_dir}" = "x" ]
then
	if [ -f "./wavpack/include/wavpack.h" ]
	then
		wavpack_dir="./wavpack"
		wavpack_libspec="-L${wavpack_dir}/src/.libs -lwavpack"
		echo "WavPack support: enabled (using submodule)"
	else
		echo "WARNING: WavPack source not found (wavpack/include/wavpack.h missing)."
		echo "  Ensure git submodules are initialized: git submodule update --init --recursive"
		echo "  Or disable WavPack: ./config --disable-wavpack"
		echo "  Or specify path: ./config --wavpack-dir=/path/to/wavpack"
		echo ""
		echo "Disabling WavPack support."
		enable_wavpack=""
	fi
fi

# Check for Zstandard submodule if enabled
if [ $enable_zstd -eq 1 ]
then
	if [ ! -f "./zstd/lib/zstd.h" ]
	then
		echo "WARNING: Zstandard source not found (zstd/lib/zstd.h missing)."
		echo "  Ensure git submodules are initialized: git submodule update --init --recursive"
		echo "  Or disable Zstandard: ./config --disable-zstd"
		echo ""
		echo "Disabling Zstandard support."
		enable_zstd=0
		zstd_objs=""
		zstd_wrapobj=""
		zstd_cppflags=""
		zstd_incflags=""
	else
		echo "Zstandard support: enabled"
	fi
else
	echo "Zstandard support: disabled"
fi

if [ $debug -eq 1 ]
then
	typ="DEBUG"
	salsa20_stream_c='\$\(XSALSA20_STREAM_C\)'
	salsa20_stream_asm=
	salsa20_debug='\$\(XSALSA20_DEBUG\)'
	extra_opt_flags="${extra_opt_flags} -fno-inline"
else
	typ="RELEASE"
fi

# ----------------------------------------------------------------
# Detect operating system and platform
# ----------------------------------------------------------------
echo "Checking OS ..."
OS=$(uname)
skeinblock='\$\(SKEIN_BLOCK_C\)'
gnu_arch=""

if [ "$OS" = "Linux" ]
then
	plat=$(uname -m)
	# Determine GNU multiarch triplet for Debian/Ubuntu library paths
	if command -v dpkg-architecture >/dev/null 2>&1; then
		gnu_arch=$(dpkg-architecture -qDEB_HOST_MULTIARCH 2>/dev/null)
	elif [ -z "$gnu_arch" ]; then
		# Fallback: construct from uname
		case "$plat" in
		x86_64)  gnu_arch="x86_64-linux-gnu" ;;
		aarch64) gnu_arch="aarch64-linux-gnu" ;;
		esac
	fi
elif [ "$OS" = "Darwin" ]
then
	plat=$(uname -m)
	so_suffix=dylib
elif [ "$OS" = "FreeBSD" ]
then
	plat=$(uname -m)
	ldl=""
	lrt=""
	dtag_val=""
elif [ "$OS" = "SunOS" ]
then
	plat=$(isainfo -v)
else
	echo "WARNING: Untested OS '$OS'. Attempting to continue ..."
	plat=$(uname -m)
fi

echo "  OS: $OS  Platform: $plat"

# ----------------------------------------------------------------
# Detect CPU architecture and disable irrelevant features
# ----------------------------------------------------------------
is_x86=0
is_arm=0
is_riscv=0
case "$plat" in
x86_64|amd64|i[3456]86)
	is_x86=1
	;;
aarch64|arm64|armv*)
	is_arm=1
	# Disable SSE/AVX detection and flags on ARM
	sse_detect=0
	avx_detect=0
	sse_opt_flags=""
	avx_opt_flag=""
	avx512_opt_flag=""
	sse4_opt_flag=""
	sse3_opt_flag=""
	sse2_opt_flag=""
	# Enable NEON compiler flags for ARM64
	neon_opt_flag="-march=armv8-a+crypto"
	;;
riscv64)
	is_riscv=1
	# Disable SSE/AVX detection and flags on RISC-V
	sse_detect=0
	avx_detect=0
	sse_opt_flags=""
	avx_opt_flag=""
	avx512_opt_flag=""
	sse4_opt_flag=""
	sse3_opt_flag=""
	sse2_opt_flag=""
	;;
esac

# ----------------------------------------------------------------
# Check compiler version
# ----------------------------------------------------------------
echo "Checking compiler version ..."

# Detect if compiler is Clang
is_clang=0
${GCC} --version 2>&1 | grep -qi clang && is_clang=1

if [ $is_clang -eq 1 ]; then
	echo "  Detected Clang compiler"
	vers=$(${GCC} -dumpversion 2>/dev/null)
	# Clang's -dumpversion often returns a high number; skip GCC version check
else
	vers=$(${GCC} -dumpversion)
	OIFS="$IFS"
	IFS=.
	set -- ${vers}
	IFS="$OIFS"

	if [ $1 -lt 4 ] || { [ $1 -eq 4 ] && [ $2 -lt 4 ]; }
	then
		echo "ERROR:"
		echo "GCC version 4.4 or above is required."
		echo "Detected version: ${vers}"
		echo ""
		echo "Set the CC environment variable to use a different compiler:"
		echo "  CC=gcc-12 ./config"
		echo ""
		exit 1
	fi
	echo "  GCC version: ${vers}"
fi

# ----------------------------------------------------------------
# SSE / AVX detection (x86 only)
# ----------------------------------------------------------------
if [ $sse_detect -eq 1 ]
then
	${GCC} -o sse_level ./utils/sse_level.c ./utils/cpuid.c -I./utils
	if [ $? -ne 0 ]
	then
		echo "ERROR:"
		echo "Failed to build SSE detection utility."
		echo ""
		exit 1
	fi
fi

if [ $sse_detect -eq 1 ]
then
	# SSE Detection
	printf "Checking for CPU SSE version ... "
	sse_ver=$(./sse_level)
	if [ $? -ne 0 ]
	then
		rm -f sse_level
		echo "ERROR:"
		echo "SSE version detection utility. Try configuring with --no-sse-detect option."
		echo ""
		exit 1
	fi
	echo "$sse_ver"
	sse_opt_flags="-m${sse_ver}"
fi

if [ $avx_detect -eq 1 ] && [ $sse_detect -eq 1 ]
then
	printf "Checking for CPU AVX version ... "
	avx_ver=$(./sse_level --avx)
	if [ $? -ne 0 ]
	then
		rm -f sse_level
		echo "ERROR:"
		echo "SSE/AVX version detection utility. Try configuring with --no-sse-detect option."
		echo ""
		exit 1
	fi
	if [ "x$avx_ver" = "x" ]
	then
		echo "None"
	else
		echo "$avx_ver"
		sse_opt_flags="${sse_opt_flags} -m${avx_ver}"
	fi
fi
rm -f sse_level

echo "$plat" | grep -E 'x86_64|amd64' > /dev/null
if [ $? -eq 0 ]
then
	if [ "$OS" != "Darwin" ]
	then
		skeinblock='\$\(SKEIN_BLOCK_ASM\)'
	fi
	yasm=

	#
	# Detect Yasm
	#
	echo "Checking for Yasm ..."

	# First, try to find yasm in PATH (for Nix, Homebrew, and other package managers)
	if command -v yasm >/dev/null 2>&1; then
		yasm_path=$(command -v yasm)
		yver=$($yasm_path --version 2>/dev/null | head -1 | awk '{print $2}')
		if [ -n "$yver" ]; then
			_OIFS=$IFS; IFS="."; set -- ${yver}; IFS="$_OIFS"
			major=$1
			minor=$2

			# Minimum yasm version 1.1
			if [ "$major" -ge 1 ] && [ "$minor" -ge 1 ]; then
				yasm=$yasm_path
				sha256asmobjs='\$\(SHA2ASM_OBJS\)'
				sha256objs='\$\(SHA2_OBJS\)'
				echo "  Found yasm $yver at $yasm_path"
			fi
		fi
	fi

	# If not found in PATH, check standard locations
	if [ "x${yasm}" = "x" ]; then
		for bindir in /bin /usr/bin /usr/local/bin /opt/homebrew/bin
		do
			if [ -x "${bindir}/yasm" ]
			then
				# Get yasm version
				yver=$(${bindir}/yasm --version | head -1 | awk '{print $2}')
				_OIFS=$IFS; IFS="."; set -- ${yver}; IFS="$_OIFS"
				major=$1
				minor=$2

				# Minimum yasm version 1.1
				if [ "$major" -lt 1 ] || [ "$minor" -lt 1 ]; then
					continue
				fi
				yasm=${bindir}/yasm
				sha256asmobjs='\$\(SHA2ASM_OBJS\)'
				sha256objs='\$\(SHA2_OBJS\)'
			fi
		done
	fi

	if [ "x${yasm}" = "x" ]
	then
		echo "  Yasm not found - assembly optimizations will be disabled"
		echo "  (Optional) Install yasm for better performance:"
		echo "    - Ubuntu/Debian: sudo apt install yasm"
		echo "    - macOS: brew install yasm"
		echo "    - Nix: nix-shell -p yasm"
		# Continue without yasm - use C implementations
		yasm="@echo Skipping"
		sha256asmobjs=
		sha256objs=
		skeinblock='\$\(SKEIN_BLOCK_C\)'
	fi

	if [ "$OS" = "Linux" ]
	then
		yasm="${yasm} ${yasm_params_linux}"

	elif [ "$OS" = "Darwin" ]
	then
		yasm="${yasm} ${yasm_params_osx}"
		yasm_params_gas="${yasm} ${yasm_params_gas_osx}"

	elif [ "$OS" = "FreeBSD" ]
	then
		yasm="${yasm} ${yasm_params_linux}"

	elif [ "$OS" = "SunOS" ]
	then
		yasm="${yasm} ${yasm_params_linux}"
	fi

	if [ $debug -eq 1 ]
	then
		keccak_srcs='\$\(KECCAK_SRC_OPT64\)'
		keccak_hdrs='\$\(KECCAK_HDRS_OPT64\)'
	else
		keccak_srcs='\$\(KECCAK_SRC_OPT64_ASM1\)'
		if [ "$OS" != "Darwin" ]
		then
			keccak_srcs_asm='\$\(KECCAK_SRC_OPT64_ASM2\)'
		else
			keccak_srcs_asm='\$\(KECCAK_SRC_OPT64_ASM3\)'
		fi
		keccak_hdrs='\$\(KECCAK_HDRS_OPT64_ASM\)'
	fi
else
	keccak_srcs='\$\(KECCAK_SRC_OPT64\)'
fi

if [ "$OS" = "Darwin" ]
then
	crypto_asm_compile='\$\(CRYPTO_ASM_COMPILE2\)'
	use_clang_as="-Wa,-q"
	soname_opt="install_name,"
	rpath="-rpath,"
	dtag_val=""
	lrt="-liconv"
	ldl=""
	max_opt="O2"
fi

if [ "$OS" = "FreeBSD" ]
then
	rpath="-rpath,"
fi

# ----------------------------------------------------------------
# Detect OpenSSL library
# ----------------------------------------------------------------
echo "Checking for OpenSSL ..."

# Try pkg-config first
if [ "x${openssl_prefix}" = "x" ]; then
	_pkglib=$(try_pkgconfig openssl)
	if [ $? -eq 0 ] && [ -n "$_pkglib" ]; then
		echo "  Found OpenSSL via pkg-config: $_pkglib"
		openssl_libdir="$_pkglib"
	fi
fi

if [ "x${openssl_libdir}" = "x" ]; then
	for lib in "${openssl_prefix}/lib64" "${openssl_prefix}/usr/lib64" \
		"${openssl_prefix}/lib" "${openssl_prefix}/usr/lib" \
		"${openssl_prefix}/ssl/lib64" "${openssl_prefix}/ssl/lib" \
		$(lib_search_paths "${openssl_prefix}")
	do
		if [ -d "${lib}" ]
		then
			if [ -f "${lib}/libcrypto.${so_suffix}" ] || [ -h "${lib}/libcrypto.${so_suffix}" ]
			then
				openssl_libdir="${lib}"
				(cd ./buildtmp; ln -s "${openssl_libdir}/libcrypto.${so_suffix}")
				break
			elif [ -f "${lib}/libcrypto.a" ]
			then
				openssl_libdir="${lib}"
				(cd ./buildtmp; ln -s "${openssl_libdir}/libcrypto.a")
				break
			fi
		fi
	done
fi

if [ "x${openssl_libdir}" = "x" ]
then
	echo "ERROR: OpenSSL libraries not detected."
	echo ""
	echo "Possible solutions:"
	if [ "$OS" = "Linux" ]; then
